/* app.wxss — ClaudeMatch 全局样式 (linQ dark theme) */

/* ===== 设计Token ===== */
page {
  --primary: #6366f1;
  --primary-light: #818cf8;
  --primary-dark: #4f46e5;
  --accent: #f472b6;
  --accent-light: #f9a8d4;
  --bg-primary: #0f172a;
  --bg-secondary: #1e293b;
  --bg-card: #1e293b;
  --bg-hover: #334155;
  --text-primary: #f8fafc;
  --text-secondary: #94a3b8;
  --text-tertiary: #64748b;
  --border: #334155;
  --border-light: rgba(51, 65, 85, 0.5);
  --success: #22c55e;
  --warning: #f59e0b;
  --error: #ef4444;
  --radius-sm: 12rpx;
  --radius: 16rpx;
  --radius-lg: 24rpx;
  --radius-xl: 32rpx;

  background-color: var(--bg-primary);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  color: var(--text-primary);
  font-size: 28rpx;
  line-height: 1.6;
}

/* ===== 通用容器 ===== */
.container {
  padding: 0 32rpx;
}

.page-padding {
  padding: 30rpx 32rpx;
}

/* ===== 卡片 ===== */
.card {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid var(--border-light);
}

.card-dark {
  background: rgba(15, 23, 42, 0.6);
}

/* ===== 按钮 ===== */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 600;
  transition: all 0.2s;
}

.btn::after {
  border: none;
}

.btn-primary {
  background: linear-gradient(135deg, #6366f1, #818cf8);
  color: #fff;
  border-radius: var(--radius-lg);
}

.btn-primary:active {
  opacity: 0.85;
}

.btn-outline {
  background: transparent;
  border: 2rpx solid var(--border);
  color: var(--text-primary);
  border-radius: var(--radius-lg);
}

.btn-ghost {
  background: transparent;
  color: var(--text-secondary);
}

.btn-sm {
  height: 64rpx;
  padding: 0 32rpx;
  font-size: 26rpx;
  border-radius: var(--radius);
}

.btn-md {
  height: 88rpx;
  padding: 0 48rpx;
  font-size: 30rpx;
  border-radius: var(--radius-lg);
}

.btn-lg {
  height: 100rpx;
  padding: 0 64rpx;
  font-size: 32rpx;
  border-radius: var(--radius-xl);
}

.btn-block {
  width: 100%;
}

/* ===== 输入框 ===== */
.input {
  background: var(--bg-secondary);
  color: var(--text-primary);
  border: 1rpx solid var(--border);
  border-radius: var(--radius-lg);
  padding: 24rpx 32rpx;
  font-size: 30rpx;
  height: 96rpx;
  box-sizing: border-box;
  transition: border-color 0.2s;
}

.input:focus {
  border-color: var(--primary);
}

.input-placeholder {
  color: var(--text-tertiary);
}

.textarea {
  background: var(--bg-secondary);
  color: var(--text-primary);
  border: 1rpx solid var(--border);
  border-radius: var(--radius-lg);
  padding: 24rpx 32rpx;
  font-size: 30rpx;
  min-height: 200rpx;
  width: 100%;
  box-sizing: border-box;
}

/* ===== 文字层级 ===== */
.text-h1 {
  font-size: 52rpx;
  font-weight: 800;
  color: var(--text-primary);
}

.text-h2 {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.text-h3 {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.text-body {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.text-small {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.text-accent {
  background: linear-gradient(135deg, #818cf8, #f472b6);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* ===== 间距 ===== */
.mt-8 { margin-top: 8rpx; }
.mt-16 { margin-top: 16rpx; }
.mt-24 { margin-top: 24rpx; }
.mt-32 { margin-top: 32rpx; }
.mt-48 { margin-top: 48rpx; }
.mb-16 { margin-bottom: 16rpx; }
.mb-24 { margin-bottom: 24rpx; }
.mb-32 { margin-bottom: 32rpx; }
.mb-48 { margin-bottom: 48rpx; }

/* ===== 通用Flex ===== */
.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-1 {
  flex: 1;
}

.gap-8 { gap: 8rpx; }
.gap-16 { gap: 16rpx; }
.gap-24 { gap: 24rpx; }
.gap-32 { gap: 32rpx; }

/* ===== 标签 ===== */
.tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.tag-primary {
  background: rgba(99, 102, 241, 0.2);
  color: #818cf8;
}

.tag-accent {
  background: rgba(244, 114, 182, 0.2);
  color: #f472b6;
}

.tag-success {
  background: rgba(34, 197, 94, 0.2);
  color: #22c55e;
}

/* ===== 加载 ===== */
.loading-center {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 64rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-tertiary);
}

/* ===== 分割线 ===== */
.divider {
  height: 1rpx;
  background: var(--border);
  margin: 24rpx 0;
}

/* ===== 安全区 ===== */
.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

/* ===== 首页专用导航栏(自定义) ===== */
.custom-navbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 32rpx;
  padding-top: calc(env(safe-area-inset-top) + 16rpx);
}
