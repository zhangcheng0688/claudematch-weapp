<!-- pages/auth/auth.wxml -->
<view class="auth-page">
  <view class="container auth-content">

    <!-- 返回 -->
    <view class="back-btn" bindtap="goBack">
      <text class="back-arrow">←</text>
    </view>

    <!-- 标题 -->
    <view class="auth-header">
      <text class="auth-title" wx:if="{{step === 'email'}}">欢迎回来</text>
      <text class="auth-title" wx:else>验证邮箱</text>
      <text class="auth-subtitle" wx:if="{{step === 'email'}}">输入你的邮箱，我们会发送 6 位验证码</text>
      <text class="auth-subtitle" wx:else>请输入发送到 {{email}} 的 6 位验证码</text>
    </view>

    <!-- 表单 -->
    <view class="form-section">

      <!-- 邮箱输入 -->
      <block wx:if="{{step === 'email'}}">
        <view class="input-group">
          <text class="input-label">邮箱</text>
          <input
            class="input auth-input"
            type="text"
            placeholder="your@email.com"
            placeholder-class="input-placeholder"
            value="{{email}}"
            bindinput="onEmailInput"
            confirm-type="done"
            bindconfirm="sendOTP"
            focus="{{true}}"
          />
        </view>
        <text class="error-text" wx:if="{{error}}">{{error}}</text>
        <button
          class="btn btn-primary auth-btn"
          bindtap="sendOTP"
          loading="{{loading}}"
        >
          发送验证码
        </button>
      </block>

      <!-- OTP 输入 -->
      <block wx:else>
        <view class="input-group">
          <text class="input-label">验证码</text>
          <input
            class="input auth-input"
            type="number"
            maxlength="6"
            placeholder="000000"
            placeholder-class="input-placeholder"
            value="{{otp}}"
            bindinput="onOtpInput"
            focus="{{true}}"
          />
        </view>
        <text class="error-text" wx:if="{{error}}">{{error}}</text>
        <button
          class="btn btn-primary auth-btn"
          loading="{{loading}}"
        >
          验证中...
        </button>

        <!-- 重发 -->
        <view class="resend-section">
          <text class="resend-text" wx:if="{{countdown > 0}}">{{countdown}}s 后可重发</text>
          <text class="resend-link" wx:else bindtap="resendOTP">重新发送验证码</text>
        </view>
      </block>
    </view>

    <!-- 底部 -->
    <view class="auth-footer">
      <text class="footer-text">继续即表示你同意 linQ 的服务条款和隐私政策</text>
    </view>
  </view>
</view>
