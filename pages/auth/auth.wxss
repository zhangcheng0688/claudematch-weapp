/* pages/auth/auth.wxss */
.auth-page {
  min-height: 100vh;
  background: #0f172a;
}

.auth-content {
  padding-top: 40rpx;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* 返回按钮 */
.back-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 48rpx;
}

.back-arrow {
  font-size: 40rpx;
  color: #94a3b8;
}

/* 标题 */
.auth-header {
  margin-bottom: 64rpx;
}

.auth-title {
  display: block;
  font-size: 52rpx;
  font-weight: 800;
  color: #f8fafc;
  margin-bottom: 20rpx;
}

.auth-subtitle {
  display: block;
  font-size: 28rpx;
  color: #94a3b8;
  line-height: 1.6;
}

/* 表单 */
.form-section {
  flex: 1;
}

.input-group {
  margin-bottom: 32rpx;
}

.input-label {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #f8fafc;
  margin-bottom: 16rpx;
}

.auth-input {
  width: 100%;
  box-sizing: border-box;
}

.error-text {
  display: block;
  font-size: 26rpx;
  color: #ef4444;
  margin-bottom: 24rpx;
}

.auth-btn {
  width: 100%;
  height: 100rpx;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: 600;
  margin-top: 16rpx;
  box-shadow: 0 8rpx 32rpx rgba(99, 102, 241, 0.3);
}

/* 重发 */
.resend-section {
  text-align: center;
  margin-top: 32rpx;
}

.resend-text {
  font-size: 26rpx;
  color: #64748b;
}

.resend-link {
  font-size: 28rpx;
  color: #818cf8;
  font-weight: 500;
}

/* 底部 */
.auth-footer {
  padding: 48rpx 0;
  text-align: center;
}

.footer-text {
  font-size: 24rpx;
  color: #64748b;
}
