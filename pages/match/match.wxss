/* pages/match/match.wxss */
.match-page {
  min-height: 100vh;
  background: #0f172a;
}

.page-title {
  display: block;
  font-size: 44rpx;
  font-weight: 800;
  color: #f8fafc;
  margin-bottom: 40rpx;
  padding-top: 80rpx;
}

.match-card {
  background: #1e293b;
  border-radius: 24rpx;
  padding: 36rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(99, 102, 241, 0.15);
  position: relative;
  overflow: hidden;
}

.match-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, #6366f1, #f472b6);
}

.match-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.match-score {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(99, 102, 241, 0.15);
  padding: 10rpx 24rpx;
  border-radius: 20rpx;
}

.score-num {
  font-size: 36rpx;
  font-weight: 800;
  color: #818cf8;
}

.score-label {
  font-size: 22rpx;
  color: #818cf8;
}

.match-name {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #f8fafc;
  margin-bottom: 12rpx;
}

.match-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.match-summary {
  font-size: 26rpx;
  color: #94a3b8;
  line-height: 1.6;
  margin-bottom: 24rpx;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.match-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1rpx solid #334155;
}

.match-time {
  font-size: 24rpx;
  color: #64748b;
}

.match-action {
  font-size: 28rpx;
  color: #818cf8;
  font-weight: 600;
}

/* 空状态 */
.match-empty {
  text-align: center;
  padding: 120rpx 0;
}

.match-empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.match-empty-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #f8fafc;
  margin-bottom: 12rpx;
}

.match-empty-desc {
  font-size: 26rpx;
  color: #94a3b8;
  margin-bottom: 48rpx;
}
