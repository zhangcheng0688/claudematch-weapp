<!-- pages/profile/profile.wxml (Phase 2 增强) -->
<view class="profile-page">
  <view class="container">

    <!-- 用户信息 -->
    <view class="profile-header">
      <view class="avatar-circle">
        <text>{{user.email ? user.email.charAt(0).toUpperCase() : '?'}}</text>
      </view>
      <text class="username">{{user.email || user.display_name || '用户'}}</text>
    </view>

    <!-- 菜单 -->
    <view class="profile-menu">
      <view class="menu-item" bindtap="goToStart">
        <text class="menu-icon">📝</text>
        <text class="menu-text">完善 AI 画像</text>
        <text class="menu-arrow">→</text>
      </view>

      <view class="menu-item" bindtap="goToSettings">
        <text class="menu-icon">⚙️</text>
        <text class="menu-text">匹配偏好设置</text>
        <text class="menu-arrow">→</text>
      </view>
    </view>

    <!-- 微信绑定 -->
    <view class="profile-menu">
      <view class="menu-item" bindtap="bindWechat">
        <text class="menu-icon">💚</text>
        <view style="flex: 1;">
          <text class="menu-text">绑定微信</text>
          <text class="menu-desc" wx:if="{{wxBound}}" style="font-size: 24rpx; color: #22c55e;">已绑定</text>
          <text class="menu-desc" wx:else style="font-size: 24rpx; color: #64748b;">绑定后可接收匹配通知</text>
        </view>
        <text class="menu-arrow" wx:if="{{!wxBound}}">→</text>
        <text class="menu-arrow" wx:else style="color: #22c55e;">✓</text>
      </view>
    </view>

    <!-- 退出登录 -->
    <view class="logout-section">
      <button class="logout-btn" bindtap="logout">退出登录</button>
    </view>

    <text class="version-text">linQ v1.1.0 · Phase 2</text>

    <view class="safe-bottom" style="height: 80rpx;"></view>
  </view>
</view>
