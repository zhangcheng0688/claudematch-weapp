/* pages/profile/profile.wxss */
.profile-page {
  min-height: 100vh;
  background: #0f172a;
}

.profile-header {
  padding: 80rpx 0 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-circle {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #6366f1, #f472b6);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 24rpx;
}

.username {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #f8fafc;
  margin-bottom: 8rpx;
}

.user-email {
  font-size: 26rpx;
  color: #94a3b8;
}

.profile-menu {
  background: #1e293b;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  border: 1rpx solid rgba(51, 65, 85, 0.5);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #334155;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  width: 48rpx;
  font-size: 36rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #f8fafc;
}

.menu-arrow {
  color: #64748b;
  font-size: 28rpx;
}

/* 退出登录 */
.logout-section {
  text-align: center;
  padding: 48rpx 0;
}

.logout-btn {
  background: none;
  border: none;
  color: #ef4444;
  font-size: 30rpx;
  padding: 20rpx;
}

.logout-btn::after {
  border: none;
}

.version-text {
  text-align: center;
  font-size: 24rpx;
  color: #475569;
  padding: 32rpx 0;
}
