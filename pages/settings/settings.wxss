/* pages/settings/settings.wxss */
.settings-page {
  min-height: 100vh;
  background: #0f172a;
}

.page-title {
  display: block;
  font-size: 44rpx;
  font-weight: 800;
  color: #f8fafc;
  margin-bottom: 40rpx;
  padding-top: 80rpx;
}

.settings-card {
  background: #1e293b;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  border: 1rpx solid rgba(51, 65, 85, 0.5);
}

.settings-header {
  display: block;
  font-size: 24rpx;
  color: #64748b;
  padding: 28rpx 32rpx 16rpx;
  text-transform: uppercase;
  letter-spacing: 2rpx;
}

.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #334155;
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-left {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.setting-label {
  font-size: 30rpx;
  color: #f8fafc;
  font-weight: 500;
}

.setting-desc {
  font-size: 24rpx;
  color: #64748b;
}

/* 开关样式 */
.switch-wrap {
  flex-shrink: 0;
}

/* 保存按钮 */
.save-section {
  padding: 48rpx 0;
}

.save-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
}

/* 退出登录 */
.logout-section {
  text-align: center;
  padding: 48rpx 0;
}

.logout-btn {
  background: none;
  border: none;
  color: #ef4444;
  font-size: 30rpx;
  padding: 20rpx;
}

.logout-btn::after {
  border: none;
}
